{
  "name": "formkit-quasar",
  "private": false,
  "version": "0.2.0",
  "type": "module",
  "homepage": "https://github.com/mathsgod/formkit-quasar",
  "description": "Formkit components for Quasar",
  "repository": {
    "type": "git",
    "url": "mathsgod/formkit-quasar"
  },
  "scripts": {
    "dev": "vite -c vite.docs.config.ts",
    "docs:dev": "vite -c vite.docs.config.ts",
    "build": "vue-tsc && vite build",
    "docs:build": "vite build -c vite.docs.config.ts",
    "preview": "vite preview",
    "release": "npm version patch && npm run build && npm publish"
  },
  "dependencies": {
    "@formkit/vue": "^2.1.0",
    "@quasar/extras": "^1.16.13",
    "quasar": "^2.17.2",
    "vue": "^3.5.12"
  },
  "peerDependencies": {
    "@formkit/core": "^2.1.0",
    "@formkit/validation": "^2.1.0"
  },
  "devDependencies": {
    "@quasar/vite-plugin": "^1.8.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "netlify-cli": "^26.1.0",
    "typescript": "^5.0.2",
    "vite": "^7.2.7",
    "vite-plugin-dts": "^4.5.4",
    "vue-router": "^4.6.4",
    "vue-tsc": "^3.1.7"
  },
  "files": [
    "dist"
  ],
  "module": "./dist/formkit-quasar.js",
  "license": "MIT",
  "types": "./dist/components/index.d.ts"
}
